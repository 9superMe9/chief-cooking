# 饭点小厨后端环境变量模板：复制为 .env 并填入真实值
APP_NAME=饭点小厨
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# SQLite 用于开发；生产建议 PostgreSQL：postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./chief_cooking.db

REDIS_URL=redis://localhost:6379/0

# 生成强密钥：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-generate-a-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 微信小程序 AppID/AppSecret（微信公众平台注册后获取）
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 百炼 AI（阿里云 DashScope）API Key
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_VISION_MODEL=qwen3.7-plus
AI_TEXT_MODEL=qwen3.7-plus
# 百炼免费额度（tokens），按自己账号实际填；用尽会日志告警。0=不告警
AI_FREE_QUOTA_TOKENS=1000000
AI_COST_WARN_RATIO=0.8

# 腾讯云 COS（图片存储）；留空则使用本地 ./uploads
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

# CORS 允许来源（逗号分隔）；生产填小程序后台域名 + H5 域名
CORS_ORIGINS=http://localhost:5173

# 后端对外公网根地址（用于拼接图片公网 URL，如 https://api.example.com）
PUBLIC_BASE_URL=

# 限流：每分钟每 IP 最大请求数
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_UPLOAD_PER_MIN=20
RATE_LIMIT_AI_PER_MIN=10
RATE_LIMIT_RECOMMEND_PER_MIN=20
